rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
        (request.auth.token.email == 'hellodienan@gmail.com' || exists(/databases/$(database)/documents/admins/$(request.auth.uid))); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'excerpt', 'category', 'date', 'readTime', 'content']) &&
             data.title is string && data.title.size() <= 200 &&
             data.excerpt is string && data.excerpt.size() <= 500 &&
             data.category is string && data.category.size() <= 100 &&
             data.date is string && data.date.size() <= 64 &&
             data.readTime is string && data.readTime.size() <= 100 &&
             data.content is string && data.content.size() <= 150000 &&
             (!('coverImage' in data) || (data.coverImage is string && data.coverImage.size() <= 1000));
    }

    function isValidSubscriber(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }
    
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(postId) && isValidBlogPost(incoming()) && incoming().keys().hasOnly(['title', 'excerpt', 'category', 'date', 'readTime', 'content', 'coverImage']);
      allow update: if isAdmin() && isValidId(postId) && isValidBlogPost(incoming());
      allow delete: if isAdmin() && isValidId(postId);
    }
    
    match /subscribers/{subscriberId} {
      allow read, delete: if isAdmin();
      allow create: if isValidSubscriber(incoming()) && incoming().keys().hasOnly(['email', 'createdAt']);
    }
    
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingsId);
    }
    
    match /admins/{adminId} {
      allow read, write: if isAdmin() && isValidId(adminId);
    }
  }
}
